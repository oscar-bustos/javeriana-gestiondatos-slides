# Ignorar todo por defecto
*

# Permitir las carpetas que queremos versionar y su contenido
!/docs/
!/docs/**
!/.agents/
!/.agents/**

# Ignorar archivos temporales dentro de las carpetas permitidas
**/.quarto/
**/*_files/
**/.ipynb_checkpoints/
**/__pycache__/
**/*.pyc

# Permitir archivos de Quarto (.qmd y .bib)
!/quarto/
!/quarto/**/
!/quarto/**/*.qmd
!/quarto/**/*.bib

# Permitir archivos específicos en la raíz
!/.gitignore
!/index.html
!/README.md



